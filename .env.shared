# Shared environment variables for backend, worker, scheduler
APP_STAGE=dev
DATABASE_URL=postgresql+asyncpg://postgres:secret@db:5432/templatepg
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/?heartbeat=600
RABBITMQ_ENABLED=true
STORAGE_ENDPOINT_INTERNAL=http://minio:9000
STORAGE_ENDPOINT_PUBLIC=${SITE_URL:-http://localhost}
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_BUCKET=media-public
STORAGE_PRIVATE_BUCKET=media-private
STORAGE_CLIPS_BUCKET=clips
STORAGE_ARCHIVE_BUCKET=media-private
STORAGE_PRESIGN_EXPIRES_SEC=600
STORAGE_USE_PATH_STYLE=true
STORAGE_AUTO_CREATE_BUCKETS=true
ARCHIVE_IMPORT_HOST_ROOT=${ARCHIVE_IMPORT_HOST_ROOT:-}
ARCHIVE_IMPORT_CONTAINER_ROOT=${ARCHIVE_IMPORT_CONTAINER_ROOT:-/imports}
ARCHIVE_IMPORT_ALLOWED_ROOTS=${ARCHIVE_IMPORT_ALLOWED_ROOTS:-/imports}
EMBEDDING_PROVIDER=${EMBEDDING_PROVIDER:-stub}
GEMINI_EMBEDDING_MODEL=${GEMINI_EMBEDDING_MODEL:-gemini-embedding-2-preview}
GEMINI_SUMMARY_MODEL=${GEMINI_SUMMARY_MODEL:-gemini-2.5-flash}
EMBEDDING_VECTOR_SIZE=${EMBEDDING_VECTOR_SIZE:-3072}
OCR_PROVIDER=${OCR_PROVIDER:-stub}
TRANSCRIPT_PROVIDER=${TRANSCRIPT_PROVIDER:-stub}
SUMMARY_PROVIDER=${SUMMARY_PROVIDER:-stub}
GOOGLE_CLOUD_PROJECT=${GOOGLE_CLOUD_PROJECT:-}
GOOGLE_CLOUD_LOCATION=${GOOGLE_CLOUD_LOCATION:-global}
GOOGLE_APPLICATION_CREDENTIALS=${GOOGLE_APPLICATION_CREDENTIALS:-}
GCS_STAGING_BUCKET=${GCS_STAGING_BUCKET:-}
GCS_STAGING_PREFIX=${GCS_STAGING_PREFIX:-archive-staging}
GCS_STAGING_LOCATION=${GCS_STAGING_LOCATION:-us-central1}
GCS_STAGING_AUTO_CREATE_BUCKET=${GCS_STAGING_AUTO_CREATE_BUCKET:-false}
TRANSCRIPT_LANGUAGE_CODES=${TRANSCRIPT_LANGUAGE_CODES:-ru-RU,en-US}
STT_SHORT_MODEL=${STT_SHORT_MODEL:-latest_short}
STT_LONG_MODEL=${STT_LONG_MODEL:-latest_long}
QDRANT_ENABLED=${QDRANT_ENABLED:-true}
QDRANT_URL=${QDRANT_URL:-http://qdrant:6333}
QDRANT_API_KEY=${QDRANT_API_KEY:-}
QDRANT_COLLECTION=${QDRANT_COLLECTION:-knowledge_corpus}
QDRANT_LOCAL_PATH=${QDRANT_LOCAL_PATH:-}
TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN:-}
TELEGRAM_CHAT_ID=${TELEGRAM_CHAT_ID:-}
INTERNAL_BOT_TOKEN=${INTERNAL_BOT_TOKEN:-change-me-internal-bot-token}
