APP_STAGE=dev
DEBUG=true

API_PORT=8080
API_HOST=0.0.0.0

SITE_URL=https://app.example.com
WEBAPP_URL=https://app.example.com/admin
MAX_PHOTO_SIZE=5

# Object storage (MinIO / S3-compatible)
STORAGE_ENDPOINT_INTERNAL=http://minio:9000
STORAGE_ENDPOINT_PUBLIC=http://localhost
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_BUCKET=media-public
STORAGE_PRIVATE_BUCKET=media-private
STORAGE_CLIPS_BUCKET=clips
STORAGE_PRESIGN_EXPIRES_SEC=600
STORAGE_USE_PATH_STYLE=true
STORAGE_AUTO_CREATE_BUCKETS=true

DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/templatepg
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_ENABLED=true

CSRF_HMAC_KEY=change-me

# Provide keys directly or via *_PATH
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public_key.pem
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/

# Optional: enable only if calling backend directly without proxy
CORS_ALLOW_ORIGINS=http://localhost:5173,https://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=

# Optional notifications
NOTIFICATIONS_PROVIDER=noop
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_AUTH_MAX_AGE_SEC=86400
INTERNAL_BOT_TOKEN=change-me-internal-bot-token

# Demo seed defaults
DEMO_ADMIN_EMAIL=admin@demo.local
DEMO_ADMIN_PASSWORD=Admin12345!
DEMO_ADMIN_USERNAME=Demo Admin
